NEXT_PUBLIC_KUMBU_API_URL=http://localhost:8080/api/v1

# JWT cookies são geridos automaticamente pelo login REST.
# Super admin inicial (criado no bootstrap do backend):
#   admin@kumbu.app / Admin123!  (alterar em produção via KUMBU_ADMIN_PASSWORD)

# Opcional: email ao denunciante (Resend)
# RESEND_API_KEY=re_xxxx
# REPORT_NOTIFY_FROM=Kumbú <apoio@kumbu.ao>
